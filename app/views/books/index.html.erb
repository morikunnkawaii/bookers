<h1>Books</h1>
<% @books.each do |book| %>
  <p>title</p>
  <span><%= book.title %></span>
  <%= link_to "Show",book_path(book.id) %> <!-- aタグでshowを作るだけではidタグには飛べなかった為、link_toで実施。link_toの後は文字を打つなら''か""で囲まないと無理と思われる。 -->

  <p>body</p>
  <span><%= book.body %></span>

<% end %>

<h1>Books</h1>
<h2>New book</h2>
<%= form_with model: @book do |f| %>
  <h4>Title<h4>
  <%= f.text_field :title %>  <!-- titleに単一行のテキストフィールド -->

  <h4>Body<h4>
  <%= f.text_area :body %>  <!-- bodyに複数行のテキストフィールド -->

  <%= f.submit 'Create Book' %>  <!-- 送信ボタン-->
<% end %>

